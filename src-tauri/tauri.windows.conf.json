{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "0.3.0-beta.3",
  "identifier": "com.tauri.example",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "visible": false,
        "title": "Tauri App",
        "width": 800,
        "height": 600,
        "minWidth": 720,
        "minHeight": 560,
        "transparent": true
      },
      {
        "label": "splashscreen",
        "url": "/splashscreen.html",
        "width": 560,
        "height": 400,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/tray.png",
      "icons/tray_black.png",
      "icons/tray_white.png"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGOTQ1ODg3MjY4RDg0NEYKUldSUGhJMG1oMWlVNzVOa1MwOVNoKzZIS2gyZUZaU1FjTjZFSk9wa0Q0cE5Sb1VlY1dmdFhuOEQK",
      "endpoints": [
        "https://github.com/lanxizhu/tauri-app/releases/latest/download/latest.json"
      ]
    }
  }
}
